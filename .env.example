# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@host:5432/vericount"

# ============================================================
# QUICKBOOKS ONLINE
# NOTE: QBO does not support creating company files via API.
# You connect an existing QBO company via OAuth below.
# Get these from https://developer.intuit.com/
# ============================================================
QBO_CLIENT_ID="AB..."
QBO_CLIENT_SECRET="..."
QBO_ENVIRONMENT="sandbox"          # "sandbox" or "production"
QBO_REDIRECT_URI="http://localhost:3001/api/qbo/callback"

# ============================================================
# PLAID
# Get from https://dashboard.plaid.com/
# ============================================================
PLAID_CLIENT_ID="..."
PLAID_SECRET="..."
PLAID_ENV="sandbox"               # "sandbox", "development", or "production"
PLAID_WEBHOOK_URL="https://your-domain.com/webhooks/plaid"

# ============================================================
# STRIPE
# Get from https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create these price IDs in your Stripe dashboard
STRIPE_STARTER_PRICE_ID="price_..."    # $79/mo
STRIPE_GROWTH_PRICE_ID="price_..."     # $149/mo
STRIPE_PRO_PRICE_ID="price_..."        # $299/mo

# ============================================================
# DOCUSIGN
# Get from https://developers.docusign.com/
# ============================================================
DOCUSIGN_INTEGRATION_KEY="..."
DOCUSIGN_USER_ID="..."
DOCUSIGN_ACCOUNT_ID="..."
DOCUSIGN_BASE_PATH="https://demo.docusign.net/restapi"   # demo or production
DOCUSIGN_PRIVATE_KEY_PATH="./docusign_private.key"
DOCUSIGN_ENGAGEMENT_TEMPLATE_ID="..."  # Template ID in your DocuSign account
DOCUSIGN_CONNECT_SECRET="..."          # Optional HMAC secret set in DocuSign Connect config

# ============================================================
# SLACK
# Get from https://api.slack.com/apps — needs channels:write, chat:write
# ============================================================
SLACK_BOT_TOKEN="xoxb-..."
SLACK_SIGNING_SECRET="..."
SLACK_WORKSPACE_TEAM_ID="T..."

# ============================================================
# ANTHROPIC (Claude)
# Get from https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY="sk-ant-..."

# ============================================================
# RESEND (Email)
# Get from https://resend.com/
# ============================================================
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="reports@yourdomain.com"
RESEND_FROM_NAME="Vericount"

# ============================================================
# CLERK (Client portal auth)
# Get from https://dashboard.clerk.com/
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ============================================================
# INTERNAL DASHBOARD
# ============================================================
DASHBOARD_SECRET="change-this-random-string"   # used as HTTP basic auth password
DASHBOARD_URL="http://localhost:3002"

# ============================================================
# APP CONFIG
# ============================================================
PORTAL_URL="http://localhost:3001"
WEBHOOKS_PORT="3000"
WEBHOOKS_INTERNAL_URL="http://localhost:3000"  # base URL of the webhooks service — used by dashboard for manual sync
NODE_ENV="development"
CRON_SECRET="change-this-random-string"        # shared secret for cron job auth + internal sync endpoint

# ============================================================
# TYPEFORM
# Get from https://developer.typeform.com/
# ============================================================
TYPEFORM_WEBHOOK_SECRET="..."
TYPEFORM_FORM_ID="..."
